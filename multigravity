usage() {
  cat <<EOF
Usage: multigravity <command> [args]

Commands:
  new <name> [options]        Create a new profile + desktop shortcut
      --shared                Share extensions & settings; isolate only accounts
      --linked                Share extensions, settings, history & cache; isolate only accounts
      --from <template>       Seed from a saved template
  list                        List existing profiles
  status                      Show running state, type, and last-used per profile
  rename <old> <new>          Rename a profile (updates its shortcut)
  delete <name>               Delete a profile and all its data
  clone <src> <dest>          Copy an existing profile
  template save <profile> <name>   Save a profile as a reusable template
  template list               List saved templates
  template delete <name>      Delete a template
  export <name> [path]        Archive a profile to tar.gz
  import <archive> [name]     Restore a profile from a tar.gz archive
  update                      Update multigravity to the latest version
  doctor                      Run a system diagnosis
  stats                       Show storage usage per profile
  completion                  Show setup instructions for shell completion
  agy <name> [args...]        Launch Antigravity CLI (agy) with the given profile
  <name> [args...]            Launch Antigravity IDE with the given profile
  help                        Show this help

Profile names: alphanumeric and hyphens only (e.g. work, personal, test-1)

Environment:
  MULTIGRAVITY_APP      Override the Antigravity IDE app path or command
  MULTIGRAVITY_CLI      Override the Antigravity CLI (agy) path or command
  MULTIGRAVITY_HOME     Override the profile storage directory
EOF
}

case "$cmd" in
new)
  shift
  new_profile "$@"
  ;;
list)
  list_profiles "${2-}"
  ;;
status)
  status_profiles
  ;;
rename)
  rename_profile "${2-}" "${3-}"
  ;;
delete)
  delete_profile "${2-}"
  ;;
clone)
  clone_profile "${2-}" "${3-}"
  ;;
template)
  shift
  template_cmd "$@"
  ;;
export)
  export_profile "${2-}" "${3-}"
  ;;
import)
  import_profile "${2-}" "${3-}"
  ;;
update)
  update_cli
  ;;
doctor)
  doctor_cli
  ;;
stats)
  profile_stats
  ;;
agy)
  shift
  if [ $# -lt 1 ]; then
    abort "usage: multigravity agy <profile> [args...]"
  fi
  launch_agy_profile "$@"
  ;;
completion)
  if [ -n "${2-}" ]; then
    generate_completion "$2"
  else
    help_completion
  fi
  ;;
help | --help | -h)
  usage
  ;;
"")
  usage
  exit 1
  ;;
*)
  launch_profile "$cmd" "${@:2}"
  ;;
esac
