#!/usr/bin/env bash
set -euo pipefail

shopt -s nullglob

BASE="${MULTIGRAVITY_HOME:-$HOME/AntigravityProfiles}"
cmd="${1-}"

abort() {
  echo "Error: $1" >&2
  exit 1
}

print_info() {
  echo "$1"
}

platform() {
  local raw
  raw="${MULTIGRAVITY_PLATFORM-}"
  if [ -z "$raw" ]; then
    raw="$(uname -s)"
  fi

  raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"

  case "$raw" in
  darwin | macos | mac | osx)
    printf '%s\n' "darwin"
    ;;
  linux)
    printf '%s\n' "linux"
    ;;
  *)
    abort "unsupported platform '$raw'. Multigravity supports macOS and Linux."
    ;;
  esac
}

profile_dir() {
  printf '%s/%s\n' "$BASE" "$1"
}

templates_dir() {
  printf '%s/.templates\n' "$BASE"
}

is_shared_profile() {
  [ -f "$(profile_dir "$1")/.shared" ]
}

user_data_dir() {
  local profile_path=$1

  case "$(platform)" in
  darwin)
    printf '%s/Library/Application Support/Antigravity\n' "$profile_path"
    ;;
  linux)
    printf '%s/.config/Antigravity\n' "$profile_path"
    ;;
  esac
}

extensions_dir() {
  local profile_path=$1
  printf '%s/.antigravity/extensions\n' "$profile_path"
}

system_user_data_dir() {
  case "$(platform)" in
  darwin) printf '%s/Library/Application Support/Antigravity\n' "$HOME" ;;
  linux) printf '%s/.config/Antigravity\n' "$HOME" ;;
  esac
}

system_extensions_dir() {
  printf '%s/.antigravity/extensions\n' "$HOME"
}

linux_launcher_dir() {
  printf '%s/.local/share/multigravity/launchers\n' "$HOME"
}

linux_launcher_path() {
  printf '%s/%s.sh\n' "$(linux_launcher_dir)" "$1"
}

linux_desktop_path() {
  printf '%s/.local/share/applications/multigravity-%s.desktop\n' "$HOME" "$1"
}

mac_shortcut_path() {
  printf '%s/Applications/Multigravity %s.app\n' "$HOME" "$1"
}

validate_name() {
  local name=$1

  if [[ -z "$name" ]]; then
    abort "profile name required"
  fi

  if ! [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9-]*$ ]]; then
    abort "profile name must start with alphanumeric and contain only letters, numbers, or hyphens"
  fi
}

command_or_path() {
  local candidate=$1

  if [ -z "$candidate" ]; then
    return 1
  fi

  if [ -d "$candidate" ] || [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if command -v "$candidate" >/dev/null 2>&1; then
    command -v "$candidate"
    return 0
  fi

  return 1
}

find_app() {
  local override candidate

  override="${MULTIGRAVITY_APP-}"
  if [ -n "$override" ] && command_or_path "$override" >/dev/null 2>&1; then
    command_or_path "$override"
    return 0
  fi

  case "$(platform)" in
  darwin)
    for candidate in \
      "/Applications/Antigravity.app" \
      "$HOME/Applications/Antigravity.app"; do
      if [ -d "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
    ;;
  linux)
    for candidate in \
      "antigravity" \
      "/usr/share/antigravity/antigravity" \
      "/usr/bin/antigravity" \
      "/usr/local/bin/antigravity" \
      "$HOME/.local/bin/antigravity" \
      "$HOME/Applications/Antigravity.AppImage"; do
      if command_or_path "$candidate" >/dev/null 2>&1; then
        command_or_path "$candidate"
        return 0
      fi
    done
    ;;
  esac

  return 1
}

require_app() {
  local app

  if ! app="$(find_app)"; then
    case "$(platform)" in
    darwin)
      abort "Antigravity.app was not found. Install Antigravity or set MULTIGRAVITY_APP to the app bundle path."
      ;;
    linux)
      abort "Antigravity was not found. Install the Linux app so 'antigravity' is on PATH, or set MULTIGRAVITY_APP to the executable path."
      ;;
    esac
  fi

  printf '%s\n' "$app"
}

find_agy() {
  local override candidate

  override="${MULTIGRAVITY_CLI-}"
  if [ -n "$override" ] && command_or_path "$override" >/dev/null 2>&1; then
    command_or_path "$override"
    return 0
  fi

  override="${MULTIGRAVITY_AGY-}"
  if [ -n "$override" ] && command_or_path "$override" >/dev/null 2>&1; then
    command_or_path "$override"
    return 0
  fi

  case "$(platform)" in
  darwin | linux)
    for candidate in \
      "agy" \
      "$HOME/.local/bin/agy" \
      "/usr/local/bin/agy" \
      "/usr/bin/agy"; do
      if command_or_path "$candidate" >/dev/null 2>&1; then
        command_or_path "$candidate"
        return 0
      fi
    done
    ;;
  esac

  return 1
}

require_agy() {
  local agy

  if ! agy="$(find_agy)"; then
    abort "Antigravity CLI (agy) was not found. Install agy or set MULTIGRAVITY_CLI to the agy executable path."
  fi

  printf '%s\n' "$agy"
}

create_profile_layout() {
  local profile_path=$1

  mkdir -p "$profile_path"
  mkdir -p "$(extensions_dir "$profile_path")"

  case "$(platform)" in
  darwin)
    mkdir -p "$profile_path/Library/Application Support"

    if [ ! -e "$profile_path/Library/Keychains" ] && [ -d "$HOME/Library/Keychains" ]; then
      ln -s "$HOME/Library/Keychains" "$profile_path/Library/Keychains"
    fi
    ;;
  linux)
    mkdir -p \
      "$profile_path/.config/Antigravity" \
      "$profile_path/.cache" \
      "$profile_path/.local/share" \
      "$profile_path/.local/state"
    ;;
  esac
}

create_shared_layout() {
  local profile_path=$1
  local sys_data sys_ext data_dir ext_dir

  sys_data="$(system_user_data_dir)"
  sys_ext="$(system_extensions_dir)"

  mkdir -p "$profile_path"
  touch "$profile_path/.shared"

  # Isolated user-data dir so accounts stay separate
  data_dir="$(user_data_dir "$profile_path")"
  mkdir -p "$data_dir/User"

  # Point settings/keybindings/snippets at the system install (read-only intent)
  if [ -d "$sys_data/User" ]; then
    local f
    for f in settings.json keybindings.json snippets; do
      if [ -e "$sys_data/User/$f" ] && [ ! -e "$data_dir/User/$f" ]; then
        ln -s "$sys_data/User/$f" "$data_dir/User/$f"
      fi
    done
  fi

  # Share the system extensions directory rather than an empty copy
  ext_dir="$(extensions_dir "$profile_path")"
  mkdir -p "$(dirname "$ext_dir")"
  if [ -d "$sys_ext" ]; then
    rm -rf "$ext_dir"
    ln -s "$sys_ext" "$ext_dir"
  else
    mkdir -p "$ext_dir"
  fi

  # CLI settings symlink
  local sys_agy_settings="$HOME/.gemini/antigravity-cli/settings.json"
  local profile_agy_settings="$profile_path/.gemini/antigravity-cli/settings.json"
  if [ -f "$sys_agy_settings" ] && [ ! -e "$profile_agy_settings" ]; then
    mkdir -p "$(dirname "$profile_agy_settings")"
    ln -s "$sys_agy_settings" "$profile_agy_settings"
  fi

  case "$(platform)" in
  darwin)
    mkdir -p "$profile_path/Library/Application Support"
    if [ ! -e "$profile_path/Library/Keychains" ] && [ -d "$HOME/Library/Keychains" ]; then
      ln -s "$HOME/Library/Keychains" "$profile_path/Library/Keychains"
    fi
    ;;
  linux)
    mkdir -p \
      "$profile_path/.cache" \
      "$profile_path/.local/share" \
      "$profile_path/.local/state"
    ;;
  esac
}

is_linked_profile() {
  [ -f "$(profile_dir "$1")/.linked" ]
}

create_linked_layout() {
  local profile_path=$1
  local sys_data sys_ext data_dir ext_dir

  sys_data="$(system_user_data_dir)"
  sys_ext="$(system_extensions_dir)"

  mkdir -p "$profile_path"
  touch "$profile_path/.linked"

  # Isolated user-data dir so accounts stay separate
  data_dir="$(user_data_dir "$profile_path")"
  mkdir -p "$data_dir/User"

  # Link settings files
  if [ -d "$sys_data/User" ]; then
    local f
    for f in settings.json keybindings.json snippets; do
      if [ -e "$sys_data/User/$f" ] && [ ! -e "$data_dir/User/$f" ]; then
        ln -s "$sys_data/User/$f" "$data_dir/User/$f"
      fi
    done

    # Share workspaces, backups, histories
    for d in workspaceStorage Backups History; do
      if [ -d "$sys_data/$d" ] && [ ! -e "$data_dir/$d" ]; then
        ln -s "$sys_data/$d" "$data_dir/$d"
      fi
    done

    # Share globalStorage subdirectories (isolate globalStorage files like vscdb and storage.json)
    if [ -d "$sys_data/User/globalStorage" ]; then
      mkdir -p "$data_dir/User/globalStorage"
      for entry in "$sys_data/User/globalStorage"/*; do
        if [ -d "$entry" ]; then
          local base_entry
          base_entry=$(basename "$entry")
          if [ ! -e "$data_dir/User/globalStorage/$base_entry" ]; then
            ln -s "$entry" "$data_dir/User/globalStorage/$base_entry"
          fi
        fi
      done
    fi
  fi

  # Share extensions
  ext_dir="$(extensions_dir "$profile_path")"
  mkdir -p "$(dirname "$ext_dir")"
  if [ -d "$sys_ext" ]; then
    rm -rf "$ext_dir"
    ln -s "$sys_ext" "$ext_dir"
  else
    mkdir -p "$ext_dir"
  fi

  # CLI (agy) configurations & data sharing
  local sys_gemini="$HOME/.gemini"
  local profile_gemini="$profile_path/.gemini"
  if [ -d "$sys_gemini" ]; then
    mkdir -p "$profile_gemini/antigravity-cli"
    if [ -f "$sys_gemini/settings.json" ] && [ ! -e "$profile_gemini/settings.json" ]; then
      ln -s "$sys_gemini/settings.json" "$profile_gemini/settings.json"
    fi
    if [ -f "$sys_gemini/antigravity-cli/settings.json" ] && [ ! -e "$profile_gemini/antigravity-cli/settings.json" ]; then
      ln -s "$sys_gemini/antigravity-cli/settings.json" "$profile_gemini/antigravity-cli/settings.json"
    fi

    for item in conversations brain cache knowledge scratch implicit log history.jsonl; do
      local sys_path="$sys_gemini/antigravity-cli/$item"
      local profile_path_item="$profile_gemini/antigravity-cli/$item"
      if [ -e "$sys_path" ] && [ ! -e "$profile_path_item" ]; then
        ln -s "$sys_path" "$profile_path_item"
      fi
    done
  fi

  case "$(platform)" in
  darwin)
    mkdir -p "$profile_path/Library/Application Support"
    if [ ! -e "$profile_path/Library/Keychains" ] && [ -d "$HOME/Library/Keychains" ]; then
      ln -s "$HOME/Library/Keychains" "$profile_path/Library/Keychains"
    fi
    ;;
  linux)
    mkdir -p \
      "$profile_path/.cache" \
      "$profile_path/.local/share" \
      "$profile_path/.local/state"
    ;;
  esac
}

script_path() {
  local installed dir

  installed="$(command -v multigravity 2>/dev/null || true)"
  if [ -n "$installed" ]; then
    printf '%s\n' "$installed"
    return 0
  fi

  dir="$(cd "$(dirname "$0")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$0")"
}

shell_quote() {
  printf '%q' "$1"
}

desktop_quote() {
  local value=$1

  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//\$/\\$}
  value=${value//\`/\\\`}
  printf '"%s"' "$value"
}

create_shortcut_darwin() {
  local profile=$1
  local app_name="Multigravity $profile"
  local app_dir
  local run_script
  local launcher
  local icon_src

  app_dir="$(mac_shortcut_path "$profile")"
  run_script="$app_dir/Contents/MacOS/run"
  launcher="$(script_path)"
  icon_src="$(dirname "$launcher")/icon.icns"

  mkdir -p "$app_dir/Contents/MacOS"
  mkdir -p "$app_dir/Contents/Resources"

  cat <<EOF >"$run_script"
#!/usr/bin/env bash
export MULTIGRAVITY_HOME=$(shell_quote "$BASE")
exec $(shell_quote "$launcher") $(shell_quote "$profile") "\$@"
EOF

  chmod +x "$run_script"

  if [ -f "$icon_src" ]; then
    cp "$icon_src" "$app_dir/Contents/Resources/icon.icns"
  fi

  cat <<EOF >"$app_dir/Contents/Info.plist"
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>run</string>
  <key>CFBundleIconFile</key>
  <string>icon</string>
  <key>CFBundleIdentifier</key>
  <string>com.multigravity.profile.$profile</string>
  <key>CFBundleName</key>
  <string>$app_name</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
</dict>
</plist>
EOF

  print_info "Shortcut created: $app_dir"
}

create_shortcut_linux() {
  local profile=$1
  local launcher_root
  local launcher_path
  local desktop_path
  local launcher

  launcher_root="$(linux_launcher_dir)"
  launcher_path="$(linux_launcher_path "$profile")"
  desktop_path="$(linux_desktop_path "$profile")"
  launcher="$(script_path)"

  mkdir -p "$launcher_root"
  mkdir -p "$(dirname "$desktop_path")"

  cat <<EOF >"$launcher_path"
#!/usr/bin/env sh
export MULTIGRAVITY_HOME=$(shell_quote "$BASE")
exec $(shell_quote "$launcher") $(shell_quote "$profile") "\$@"
EOF

  chmod +x "$launcher_path"

  cat <<EOF >"$desktop_path"
[Desktop Entry]
Version=1.0
Type=Application
Name=Multigravity $profile
Comment=Launch the $profile Antigravity profile
Exec=$(desktop_quote "$launcher_path") %F
Icon=antigravity
Terminal=false
StartupNotify=false
StartupWMClass=Antigravity
Categories=TextEditor;Development;IDE;
MimeType=application/x-antigravity-workspace;
EOF

  print_info "Shortcut created: $desktop_path"
}

create_shortcut() {
  case "$(platform)" in
  darwin)
    create_shortcut_darwin "$1"
    ;;
  linux)
    create_shortcut_linux "$1"
    ;;
  esac
}

remove_shortcut() {
  local profile=$1
  local target

  case "$(platform)" in
  darwin)
    target="$(mac_shortcut_path "$profile")"
    if [ -d "$target" ]; then
      rm -rf "$target"
      print_info "Removed shortcut: $target"
    fi
    ;;
  linux)
    target="$(linux_launcher_path "$profile")"
    if [ -f "$target" ]; then
      rm -f "$target"
      print_info "Removed shortcut: $target"
    fi

    target="$(linux_desktop_path "$profile")"
    if [ -f "$target" ]; then
      rm -f "$target"
      print_info "Removed shortcut: $target"
    fi
    ;;
  esac
}

launch_profile() {
  local profile=$1
  shift || true

  local profile_path
  local app
  local data_dir
  local ext_dir

  profile_path="$(profile_dir "$profile")"
  if [ ! -d "$profile_path" ]; then
    abort "profile '$profile' does not exist. Run: multigravity new $profile"
  fi

  if is_linked_profile "$profile"; then
    create_linked_layout "$profile_path"
  elif is_shared_profile "$profile"; then
    create_shared_layout "$profile_path"
  else
    create_profile_layout "$profile_path"
  fi

  app="$(require_app)"
  data_dir="$(user_data_dir "$profile_path")"
  ext_dir="$(extensions_dir "$profile_path")"

  print_info "Launching Antigravity profile '$profile'"

  case "$(platform)" in
  darwin)
    HOME="$profile_path" open -n "$app" --args \
      --user-data-dir "$data_dir" \
      --extensions-dir "$ext_dir" \
      "$@"
    ;;
  linux)
    HOME="$profile_path" \
      XDG_CONFIG_HOME="$profile_path/.config" \
      XDG_CACHE_HOME="$profile_path/.cache" \
      XDG_DATA_HOME="$profile_path/.local/share" \
      XDG_STATE_HOME="$profile_path/.local/state" \
      "$app" \
      --user-data-dir "$data_dir" \
      --extensions-dir "$ext_dir" \
      "$@"
    ;;
  esac
}

launch_agy_profile() {
  local profile=$1
  shift || true

  local profile_path
  local agy

  profile_path="$(profile_dir "$profile")"
  if [ ! -d "$profile_path" ]; then
    abort "profile '$profile' does not exist. Run: multigravity new $profile"
  fi

  if is_linked_profile "$profile"; then
    create_linked_layout "$profile_path"
  elif is_shared_profile "$profile"; then
    create_shared_layout "$profile_path"
  else
    create_profile_layout "$profile_path"
  fi

  agy="$(require_agy)"

  print_info "Launching Antigravity CLI 'agy' with profile '$profile'"

  case "$(platform)" in
  darwin)
    export HOME="$profile_path"
    export MULTIGRAVITY_PROFILE="$profile"
    exec "$agy" "$@"
    ;;
  linux)
    export HOME="$profile_path"
    export XDG_CONFIG_HOME="$profile_path/.config"
    export XDG_CACHE_HOME="$profile_path/.cache"
    export XDG_DATA_HOME="$profile_path/.local/share"
    export XDG_STATE_HOME="$profile_path/.local/state"
    export MULTIGRAVITY_PROFILE="$profile"
    exec "$agy" "$@"
    ;;
  esac
}

list_profiles() {
  local entries=""
  local dir
  local raw=${1-}

  if [ "$raw" != "--raw" ]; then
    echo "Existing profiles:"
  fi

  if [ ! -d "$BASE" ]; then
    if [ "$raw" != "--raw" ]; then
      echo "(none)"
    fi
    return 0
  fi

  for dir in "$BASE"/*; do
    [ -d "$dir" ] || continue
    local n
    n="$(basename "$dir")"
    [ "$n" = ".templates" ] && continue

    if [ "$raw" = "--raw" ]; then
      entries="${entries}${n}"$'\n'
    else
      local suffix=""
      if [ -f "$dir/.shared" ]; then
        suffix=" (shared)"
      elif [ -f "$dir/.linked" ]; then
        suffix=" (linked)"
      fi
      entries="${entries}${n}${suffix}"$'\n'
    fi
  done

  if [ -z "$entries" ]; then
    if [ "$raw" != "--raw" ]; then
      echo "(none)"
    fi
  else
    printf '%s' "$entries" | sort
  fi
}

new_profile() {
  local profile="" shared=false linked=false from_tpl=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --shared) shared=true ;;
    --linked) linked=true ;;
    --from)
      from_tpl="${2-}"
      shift
      ;;
    -*) abort "unknown option: $1" ;;
    *) profile="$1" ;;
    esac
    shift
  done

  if [ "$shared" = true ] && [ "$linked" = true ]; then
    abort "cannot specify both --shared and --linked"
  fi

  validate_name "$profile"

  local profile_path
  profile_path="$(profile_dir "$profile")"
  if [ -d "$profile_path" ]; then
    abort "profile '$profile' already exists"
  fi

  mkdir -p "$BASE"

  if [ -n "$from_tpl" ]; then
    local tpl_path
    tpl_path="$(templates_dir)/$from_tpl"
    [ -d "$tpl_path" ] || abort "template '$from_tpl' not found. Run: multigravity template list"
    print_info "Creating profile '$profile' from template '$from_tpl'..."
    cp -R "$tpl_path" "$profile_path"
  elif [ "$shared" = true ]; then
    create_shared_layout "$profile_path"
  elif [ "$linked" = true ]; then
    create_linked_layout "$profile_path"
  else
    create_profile_layout "$profile_path"
  fi

  print_info "Created profile '$profile'"
  create_shortcut "$profile"
}

delete_profile() {
  local profile=$1
  local profile_path
  local confirm

  validate_name "$profile"

  profile_path="$(profile_dir "$profile")"
  if [ ! -d "$profile_path" ]; then
    abort "profile '$profile' does not exist"
  fi

  read -r -p "Delete profile '$profile' and all its data? [y/N] " confirm
  if [[ "$confirm" =~ ^[Yy]$ ]]; then
    rm -rf "$profile_path"
    remove_shortcut "$profile"
    print_info "Deleted profile '$profile'"
  else
    print_info "Aborted."
  fi
}

rename_profile() {
  local old=$1
  local new=$2
  local old_path
  local new_path

  validate_name "$old"
  validate_name "$new"

  old_path="$(profile_dir "$old")"
  new_path="$(profile_dir "$new")"

  if [ ! -d "$old_path" ]; then
    abort "profile '$old' does not exist"
  fi
  if [ -d "$new_path" ]; then
    abort "profile '$new' already exists"
  fi

  mv "$old_path" "$new_path"
  remove_shortcut "$old"
  create_shortcut "$new"

  print_info "Renamed profile '$old' to '$new'"
}

clone_profile() {
  local src=$1
  local dest=$2
  local src_path
  local dest_path

  validate_name "$src"
  validate_name "$dest"

  src_path="$(profile_dir "$src")"
  dest_path="$(profile_dir "$dest")"

  if [ ! -d "$src_path" ]; then
    abort "source profile '$src' does not exist"
  fi
  if [ -d "$dest_path" ]; then
    abort "destination profile '$dest' already exists"
  fi

  print_info "Cloning profile '$src' to '$dest'..."
  cp -R "$src_path" "$dest_path"
  create_shortcut "$dest"

  print_info "Successfully cloned '$src' to '$dest'"
}

doctor_cli() {
  local errors=0
  local warnings=0

  print_info "Checking multigravity environment..."

  # 1. Platform Check
  if platform &>/dev/null; then
    echo "  [✓] Platform: $(platform)"
  else
    echo "  [✗] Platform: Unknown"
    errors=$((errors + 1))
  fi

  # 2. Antigravity IDE Installation
  if app=$(find_app); then
    echo "  [✓] Antigravity IDE: Found at $app"
  else
    echo "  [!] Antigravity IDE: Not found. (Optional if using only CLI)"
    warnings=$((warnings + 1))
  fi

  # 2b. Antigravity CLI (agy) Installation
  if agy=$(find_agy); then
    echo "  [✓] Antigravity CLI (agy): Found at $agy"
  else
    echo "  [!] Antigravity CLI (agy): Not found. (Optional if using only IDE)"
    warnings=$((warnings + 1))
  fi

  # 3. Path Check
  local installed
  installed="$(command -v multigravity 2>/dev/null || true)"
  if [ -n "$installed" ]; then
    echo "  [✓] Global Binary: $installed"
  else
    echo "  [!] Global Binary: Not found in PATH. Run install script or update PATH."
    warnings=$((warnings + 1))
  fi

  # 4. Icon Check (macOS)
  if [ "$(platform)" = "darwin" ]; then
    local icon_path
    icon_path="$(dirname "$(script_path)")/icon.icns"
    if [ -f "$icon_path" ]; then
      echo "  [✓] Application Icon: Found"
    else
      echo "  [!] Application Icon: Missing ($icon_path). Shortcuts will have default icons."
      warnings=$((warnings + 1))
    fi
  fi

  # 5. Base Directory
  if [ -d "$BASE" ]; then
    if [ -w "$BASE" ]; then
      echo "  [✓] Profile storage: $BASE (writable)"
    else
      echo "  [✗] Profile storage: $BASE (NOT writable)"
      errors=$((errors + 1))
    fi
  else
    echo "  [!] Profile storage: $BASE (Not yet created)"
  fi

  echo ""
  if [ $errors -eq 0 ]; then
    if [ $warnings -eq 0 ]; then
      print_info "✓ Your environment looks perfect!"
    else
      print_info "Found $warnings warning(s). Multigravity should still work, but some features might be degraded."
    fi
  else
    print_info "✗ Found $errors error(s) and $warnings warning(s). Please fix the errors above."
  fi
}

profile_stats() {
  if [ ! -d "$BASE" ]; then
    print_info "No profiles found."
    return 0
  fi

  print_info "Profile Storage Usage:"
  printf "%-20s %-10s %-10s\n" "PROFILE" "SIZE" "EXTENSIONS"
  printf "%-20s %-10s %-10s\n" "-------" "----" "----------"

  local dir
  for dir in "$BASE"/*; do
    [ -d "$dir" ] || continue
    local name
    name=$(basename "$dir")
    [ "$name" = ".templates" ] && continue

    local size
    size=$(du -sh "$dir" | cut -f1)

    local ext_count
    ext_count=$(ls -1 "$(extensions_dir "$dir")" 2>/dev/null | wc -l | xargs)
    [ -z "$ext_count" ] && ext_count=0

    printf "%-20s %-10s %-10s\n" "$name" "$size" "$ext_count"
  done

  echo ""
  local total
  total=$(du -sh "$BASE" | cut -f1)
  print_info "Total usage: $total"
}

status_profiles() {
  if [ ! -d "$BASE" ]; then
    print_info "No profiles found."
    return 0
  fi

  printf "%-18s %-10s %-12s %-20s %s\n" "PROFILE" "RUNNING" "TYPE" "LAST USED" "SIZE"
  printf "%-18s %-10s %-12s %-20s %s\n" "-------" "-------" "----" "---------" "----"

  local dir
  for dir in "$BASE"/*; do
    [ -d "$dir" ] || continue
    local name
    name="$(basename "$dir")"
    [ "$name" = ".templates" ] && continue

    local running="no"
    local data_dir
    data_dir="$(user_data_dir "$dir")"
    if ps -eo args 2>/dev/null | grep -v grep | grep -qF "$data_dir"; then
      running="yes"
    fi

    local ptype="full"
    if [ -f "$dir/.shared" ]; then
      ptype="shared"
    elif [ -f "$dir/.linked" ]; then
      ptype="linked"
    fi

    local last_used
    case "$(platform)" in
    darwin) last_used=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$dir" 2>/dev/null || echo "unknown") ;;
    linux) last_used=$(stat -c "%y" "$dir" 2>/dev/null | cut -d'.' -f1 || echo "unknown") ;;
    esac

    local size
    size="$(du -sh "$dir" 2>/dev/null | cut -f1)"

    if [ "$running" = "yes" ]; then
      printf "%-18s \033[32m%-10s\033[0m %-12s %-20s %s\n" "$name" "$running" "$ptype" "$last_used" "$size"
    else
      printf "%-18s %-10s %-12s %-20s %s\n" "$name" "$running" "$ptype" "$last_used" "$size"
    fi
  done
}

template_cmd() {
  local subcmd="${1-}"
  shift || true

  case "$subcmd" in
  save)
    local profile="${1-}" tpl_name="${2-}"
    validate_name "$profile"
    validate_name "$tpl_name"
    local src_path tpl_dir tpl_path
    src_path="$(profile_dir "$profile")"
    [ -d "$src_path" ] || abort "profile '$profile' does not exist"
    tpl_dir="$(templates_dir)"
    tpl_path="$tpl_dir/$tpl_name"
    [ -d "$tpl_path" ] && abort "template '$tpl_name' already exists"
    mkdir -p "$tpl_dir"
    print_info "Saving '$profile' as template '$tpl_name'..."
    cp -R "$src_path" "$tpl_path"
    rm -f "$tpl_path/.shared"
    print_info "Saved template '$tpl_name'"
    ;;
  list)
    local tpl_dir
    tpl_dir="$(templates_dir)"
    echo "Templates:"
    if [ ! -d "$tpl_dir" ]; then
      echo "  (none)"
      return 0
    fi
    local any=false
    for d in "$tpl_dir"/*; do
      [ -d "$d" ] || continue
      any=true
      printf "  %-20s %s\n" "$(basename "$d")" "$(du -sh "$d" 2>/dev/null | cut -f1)"
    done
    [ "$any" = false ] && echo "  (none)"
    ;;
  delete)
    local tpl_name="${1-}"
    validate_name "$tpl_name"
    local tpl_path
    tpl_path="$(templates_dir)/$tpl_name"
    [ -d "$tpl_path" ] || abort "template '$tpl_name' does not exist"
    rm -rf "$tpl_path"
    print_info "Deleted template '$tpl_name'"
    ;;
  *)
    abort "usage: multigravity template <save|list|delete>"
    ;;
  esac
}

export_profile() {
  local profile="${1-}" out="${2-}"
  validate_name "$profile"

  local profile_path
  profile_path="$(profile_dir "$profile")"
  [ -d "$profile_path" ] || abort "profile '$profile' does not exist"

  [ -z "$out" ] && out="./${profile}.tar.gz"

  print_info "Exporting '$profile' to $out ..."
  tar -czf "$out" -C "$BASE" "$profile"
  print_info "Done."
}

import_profile() {
  local archive="${1-}" profile="${2-}"

  [ -n "$archive" ] || abort "usage: multigravity import <archive.tar.gz> [name]"
  [ -f "$archive" ] || abort "file not found: $archive"

  if [ -z "$profile" ]; then
    profile="$(tar -tzf "$archive" 2>/dev/null | head -1 | cut -d'/' -f1)"
    [ -n "$profile" ] || abort "cannot infer profile name from archive — pass a name explicitly"
  fi

  validate_name "$profile"

  local dest
  dest="$(profile_dir "$profile")"
  [ -d "$dest" ] && abort "profile '$profile' already exists — choose a different name or delete it first"

  mkdir -p "$BASE"
  print_info "Importing as '$profile'..."

  local top_dir
  top_dir="$(tar -tzf "$archive" 2>/dev/null | head -1 | cut -d'/' -f1)"
  tar -xzf "$archive" -C "$BASE"
  if [ -n "$top_dir" ] && [ "$top_dir" != "$profile" ] && [ -d "$BASE/$top_dir" ]; then
    mv "$BASE/$top_dir" "$dest"
  fi

  create_shortcut "$profile"
  print_info "Imported profile '$profile'"
}

update_cli() {
  local script_url="https://raw.githubusercontent.com/sujitagarwal/multigravity-cli/main/multigravity"
  local target
  target="$(script_path)"

  if [ -z "$target" ]; then
    abort "could not determine script path for update"
  fi

  print_info "Updating multigravity from $script_url ..."
  if curl -fsSL "$script_url" -o "$target.tmp"; then
    mv "$target.tmp" "$target"
    chmod +x "$target"
    print_info "Successfully updated multigravity!"
  else
    rm -f "$target.tmp"
    abort "failed to download update"
  fi
}

help_completion() {
  local shell_name
  shell_name="$(basename "$SHELL")"

  echo "To enable autocompletion, add the following to your shell profile:"
  echo ""
  case "$shell_name" in
  zsh)
    echo "  # Add to ~/.zshrc"
    echo '  source <(multigravity completion zsh)'
    ;;
  bash)
    echo "  # Add to ~/.bashrc"
    echo '  source <(multigravity completion bash)'
    ;;
  fish)
    echo "  # Run in your terminal:"
    echo '  mkdir -p ~/.config/fish/completions'
    echo '  multigravity completion fish > ~/.config/fish/completions/multigravity.fish'
    ;;
  *)
    echo "  # Your shell ($shell_name) is not natively supported for completion."
    ;;
  esac
  echo ""
  if [ "$shell_name" = "fish" ]; then
    echo "Then restart your terminal or run: source ~/.config/fish/config.fish"
  else
    echo "Then restart your terminal or run: source ~/.$shell_name""rc"
  fi
}

